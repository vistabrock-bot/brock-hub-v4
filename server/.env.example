# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: https://app.supabase.com → Project Settings → API

# Your Supabase project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Service-role key (NEVER expose to the browser — server only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anon/public key (safe for browser but kept here for the server anon client)
SUPABASE_ANON_KEY=your-anon-public-key

# ─── Anthropic ───────────────────────────────────────────────────────────────
# https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: override default max tokens per request (default: 1200)
# ANTHROPIC_MAX_TOKENS=1200

# ─── Server ──────────────────────────────────────────────────────────────────
# Port the Express server listens on (default: 4000)
PORT=4000

# Comma-separated list of allowed CORS origins
# Add your Netlify/Vercel frontend URL here for production
ALLOWED_ORIGINS=http://localhost:3000,https://brock-family-app.netlify.app

# Base URL used when generating invitation links sent to users
APP_BASE_URL=http://localhost:3000

# ─── Google Calendar OAuth 2.0 ───────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Scopes needed: https://www.googleapis.com/auth/calendar
#                https://www.googleapis.com/auth/calendar.events

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# This URI must be added to your Google Cloud Console OAuth 2.0 "Authorized redirect URIs"
# Development:
GOOGLE_REDIRECT_URI=http://localhost:4000/api/gcal/callback
# Production (uncomment and set):
# GOOGLE_REDIRECT_URI=https://your-api.onrender.com/api/gcal/callback

# Secret used to sign/verify the OAuth state parameter (any long random string)
# Falls back to SUPABASE_SERVICE_ROLE_KEY if not set.
GOOGLE_STATE_SECRET=your-random-secret-string

# ─── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated list of email addresses that have admin access.
# Users can also be granted admin role via the Supabase dashboard by setting
# app_metadata.role = "admin" in their user record.
ADMIN_EMAILS=admin@example.com
