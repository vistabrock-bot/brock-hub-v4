# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: https://app.supabase.com → Project Settings → API

# Your Supabase project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Service-role key (NEVER expose to the browser — server only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anon/public key (safe for browser but kept here for the server anon client)
SUPABASE_ANON_KEY=your-anon-public-key

# ─── Anthropic ───────────────────────────────────────────────────────────────
# https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: override default max tokens per request (default: 1200)
# ANTHROPIC_MAX_TOKENS=1200

# ─── Server ──────────────────────────────────────────────────────────────────
# Port the Express server listens on (default: 4000)
PORT=4000

# Comma-separated list of allowed CORS origins
# Add your Netlify/Vercel frontend URL here for production
ALLOWED_ORIGINS=http://localhost:3000,https://brock-family-app.netlify.app

# Base URL used when generating invitation links sent to users
APP_BASE_URL=http://localhost:3000
