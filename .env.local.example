# Frontend environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and will NOT be committed.

# ─── Backend API ─────────────────────────────────────────────────────────────
# URL of the /server Express backend.
# Local development (run `npm run dev` in /server first):
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Production — replace with your deployed server URL, e.g.:
# NEXT_PUBLIC_API_BASE_URL=https://your-api.onrender.com

# ─── Supabase (frontend / public values only) ─────────────────────────────────
# Found in Supabase Dashboard → Project Settings → API → Project URL / anon key.
# These are safe to expose to the browser (they are public keys).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
